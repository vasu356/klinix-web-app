# Klinix Environment Configuration
# Copy this file to .env.local and fill in your values

# Application
VITE_APP_TITLE=Klinix — AI Patient Intake for Dental Clinics
VITE_APP_DESCRIPTION=AI-powered patient intake platform for modern dental practices

# API Configuration (for production)
# VITE_API_URL=https://api.klinix.com
# VITE_API_TIMEOUT=30000

# Analytics (optional)
# VITE_ANALYTICS_ID=your_analytics_id
# VITE_ANALYTICS_ENABLED=false

# Feature Flags
# VITE_ENABLE_DARK_MODE=true
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_SENTRY=false

# Development
# VITE_DEV_MODE=true